  "global_rules": {
    "mail_out_report_attached": "Always returns Undetermined",
    "attachment_dependency": "If attachments must be opened and message body lacks info → Undetermined",
    "multi_folder_ambiguity": "If multiple folders match after exclusion logic → Undetermined",
    "inference_failure": "If inference engine crashes or times out → Undetermined"
  }
