        "food business notification", "inspection", "permits", "business registration",
        "temporary food business notification", "business enquiry", "skin penetration",
        "skin clinic", "beauty", "approval to operate", "food complaint",
        "cleanliness", "food safety", "food labelling"
      ],
      "exclusions": [
        "If payment confirmations, fees, or financial statements only → Finance folders",
        "If waste logistics (collection, bins, delivery, pickup) → Waste Management"
      ],
      "status": "active",
      "allow_others": true,
      "sub_items": {
        "food_business_registration": {
          "name": "Food Business Registration",
          "triggers": ["food business notification", "register food business", "food premises"]
        },
        "health_inspection": {
          "name": "Health Inspection",
          "triggers": ["inspection", "health inspection", "compliance check", "food safety audit"]
        },
        "skin_penetration": {
          "name": "Skin Penetration Registration",
          "triggers": ["skin penetration", "tattoo", "beauty salon", "skin clinic", "waxing"]
        },
        "food_complaint": {
          "name": "Food Complaint",
          "triggers": ["food complaint", "food poisoning", "unclean", "hygiene concern"]
        }
      }
    },
