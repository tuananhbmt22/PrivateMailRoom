{
  "version": "2.0.0",
  "council": "Example Council",
  "purpose": "Classification with sub-item identification. Routes emails to folders and identifies the event type within each folder.",
  "confidence_threshold": 0.70,
  "fallback": "Undetermined",
  "evaluation_priority": [
    "junk",
    "fire_safety_services",
    "nhvr_applications_request",
    "nhvr_permit_issued",
    "roads_development_services",
    "environmental_compliance_illegal_dumping",
    "regulation_of_parking",
    "companion_animals",
    "onsite_sewage_management",
    "waste_management_operations",
    "regulated_premises",
    "remittance_statements",
    "finance_remittance_advices",
    "financial_management_debtors",
    "rates_general_matters",
    "rates_name_address_change",
    "sewerage_drainage",
    "roads_maintenance",
    "building_control_property_enquiries"
  ],
  "folders": {
    "rates_general_matters": {
      "name": "Rates General Matters",
      "description": "Rates refunds, adjustments, extensions, overpayments, authority to act, deceased estates, reissue requests, paperless/email delivery",
      "triggers": [
        "rates enquiry", "rates adjustment", "overpaid", "rates outstanding",
        "estate of the late", "reissue rates", "rates refund", "refund request",
        "authority to act", "paperless", "email rates"
      ],
      "exclusions": [
        "If no mention of rates, billing terms, or property ownership → Undetermined"
      ],
      "status": "active",
      "allow_others": true,
      "sub_items": {
        "rates_refund": {
          "name": "Rates Refund Request",
          "triggers": ["refund", "overpaid", "overpayment", "credit"]
        },
        "rates_adjustment": {
          "name": "Rates Adjustment",
          "triggers": ["adjustment", "reassessment", "incorrect rates", "rates review"]
        },
        "rates_extension": {
          "name": "Payment Extension",
          "triggers": ["extension", "hardship", "payment plan", "defer"]
        },
        "rates_reissue": {
          "name": "Reissue Request",
          "triggers": ["reissue", "duplicate", "lost notice", "copy of rates"]
        },
        "rates_authority": {
          "name": "Authority to Act",
          "triggers": ["authority to act", "agent", "representative", "solicitor"]
        },
        "rates_deceased": {
          "name": "Deceased Estate",
          "triggers": ["deceased", "estate of the late", "probate", "executor"]
        }
      }
    },
    "regulated_premises": {
      "name": "Regulated Premises",
      "description": "Food business registration, food trucks, mobile vendors, home-based food, beauty salons, skin clinics, tattooing, waxing, skin penetration, health inspections, compliance",
