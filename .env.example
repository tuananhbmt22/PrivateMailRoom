# Kajima Mailroom Appliance Configuration

# Paths (absolute paths on the appliance)
RECEIVE_CHANNEL=/data/receive_channel
JUNK_DIR=/data/junk
UNDETERMINED_DIR=/data/undetermined
DEPARTMENTS_BASE=/data/departments
SKILLS_DIR=/opt/mailroom/skills
DB_PATH=/opt/mailroom/db/mailroom.db

# LLM Configuration
LLM_API_URL=http://127.0.0.1:8080/v1
LLM_MODEL=local-multimodal
LLM_GPU_LAYERS=99
LLM_CONTEXT_SIZE=8192
LLM_TIMEOUT_SECONDS=60

# Classification
CONFIDENCE_THRESHOLD=0.7
WATCHER_DEBOUNCE_SECONDS=2.0

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
DASHBOARD_SECRET_KEY=change-me-on-deploy

# Notifications (local SMTP)
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_FROM=mailroom@council.local
NOTIFY_UNDETERMINED=true
NOTIFY_CRASH=true

# Integrations (optional)
CM9_ENABLED=false
CM9_API_URL=http://cm9.council.local/api
CM9_API_KEY=

TECHONE_ENABLED=false
TECHONE_API_URL=http://techone.council.local/api
TECHONE_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s [%(levelname)s] %(name)s: %(message)s
